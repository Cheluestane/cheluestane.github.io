<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>D. F. Animator</title>
		<link rel="stylesheet" href="/styles.css">
		<meta name="viewport" content="width=device-width, initial-scale=1.0">
  </head>
  <body>
  	<button class="nav-toggle" aria-expanded="false" aria-controls="sidebar" type="button">Menu</button>
  	<div class="container">
		<div class="sidebar" id="sidebar">
			<div class="homebutton">
				<a href=/>
					<img src="/content/name.png" alt="name_img" style="max-height: 200px; max-width: 80%; display: block; margin: 10px auto;"/>
					<h2 style="margin: 8px;	text-align: center;">2D/3D Animator <br> and 3D generalist.</h2>
				</a>
			</div>
			<div class="navbar">
				{{ for item of nav }}
				<form action="{{ item.url }}">
					<input type="submit" value="{{ item.name }}" />
				</form>
				{{ /for }}
			</div>
		</div>
		{{ if category }}
		<div class="displaypanel">
			{{ for child of search.pages("url^=" + url) }}
			{{ if child.url !== url && !child.url.slice(url.length, -1).includes("/") }}
			<a href="{{ child.url }}">
				<div class="panelcontent">
				<h5 style="color: white; position: absolute; bottom: 0px; z-index: 1;">{{ child.title }}</h5>
					<img src="{{ child.url }}{{ child.thumbnail }}" class="panel_img" alt="Thumbnail">
				</div>
			</a>
			{{ /if }}
			{{ /for }}
		</div>
		{{ /if }}
		{{ if !category }}
		<div class="project_page_container">
			<div class="markdownpanel">
				{{ content }}
			</div>
			{{ if description }}
			<div class="description">
				{{ description |> md |> safe }}
			</div>
			{{ /if }}
		</div>
		{{ /if }}
	</div>
  </div>
  </body>
  <div id="lightbox" class="lightbox" hidden>
  	<img id="lightbox-img" alt="">
  </div>
  <script>
  	(function () {
  		var toggle = document.querySelector('.nav-toggle');
  		var sidebar = document.getElementById('sidebar');
  		if (toggle && sidebar) {
  			toggle.addEventListener('click', function () {
  				var open = sidebar.classList.toggle('open');
  				toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
  			});
  		}

  		var lightbox = document.getElementById('lightbox');
  		var lightboxImg = document.getElementById('lightbox-img');
  		if (!lightbox || !lightboxImg) return;

  		var panel = document.querySelector('.markdownpanel');
  		if (!panel) return;

  		panel.addEventListener('click', function (e) {
  			var target = e.target;
  			if (target && target.tagName === 'IMG') {
  				lightboxImg.src = target.src;
  				lightboxImg.alt = target.alt || '';
  				lightbox.hidden = false;
  				document.body.style.overflow = 'hidden';
  			}
  		});

  		function close() {
  			lightbox.hidden = true;
  			lightboxImg.src = '';
  			document.body.style.overflow = '';
  		}

  		lightbox.addEventListener('click', close);
  		document.addEventListener('keydown', function (e) {
  			if (e.key === 'Escape' && !lightbox.hidden) close();
  		});
  	})();
  </script>
</html>
